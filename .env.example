# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Settings
LLM_PROVIDER=openai  # Options: "openai" or "gemini"
LLM_API_KEY="your-llm-api-key" # OpenAI API key (sk-...) or Google AI key (AI...)
LLM_MODEL=gpt-4o-mini  # OpenAI: gpt-4o-mini, gpt-4o | Gemini: gemini-1.5-flash, gemini-1.5-pro
DEFAULT_LLM_TEMPERATURE=0.2

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_URL="postgresql://:your-db-password@POSTGRES_HOST:POSTGRES_PORT/POSTGRES_DB"
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# Chatwoot Integration Settings
CHATWOOT_ENABLED=false
CHATWOOT_BASE_URL="https://app.chatwoot.com"
CHATWOOT_API_ACCESS_TOKEN="your-chatwoot-api-access-token"
CHATWOOT_ACCOUNT_ID=1
# Optimized for performance - shorter timeouts and fewer retries
CHATWOOT_TIMEOUT=15
CHATWOOT_MAX_RETRIES=2
RATE_LIMIT_CHATWOOT_WEBHOOK="100 per minute"

# Redis Configuration
REDIS_ENABLED=true
REDIS_URL="redis://localhost:6379/0"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_KEEPALIVE=true

# Cache Configuration - Optimized for performance
CACHE_TTL_SECONDS=600
CACHE_MESSAGE_COUNT_TTL=600
CACHE_CONVERSATION_TTL=1800
CACHE_CONTACT_TTL=3600

# PostgreSQL Connection Pool Configuration (for LangGraph AsyncConnectionPool)
POSTGRES_CONNECT_TIMEOUT=10      # Connection timeout in seconds
POSTGRES_POOL_TIMEOUT=30         # Pool checkout timeout in seconds  
POSTGRES_MAX_IDLE=300           # Max idle time in seconds (5 minutes)
POSTGRES_MAX_LIFETIME=3600      # Max connection lifetime in seconds (1 hour)
